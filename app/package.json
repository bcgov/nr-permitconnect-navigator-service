{
  "name": "nr-permitting-navigator-service-app",
  "version": "0.10.0",
  "license": "Apache-2.0",
  "private": true,
  "description": "Permit Connect Navigator Service",
  "author": "NRM Permitting and Data Solutions <NRM.PermittingAndData@gov.bc.ca>",
  "main": "server.ts",
  "scripts": {
    "build:all": "tsx ./deploy-utils.ts",
    "build": "tsc --project tsconfig.build.json",
    "clean:all": "tsx ./deploy-utils.ts clean",
    "clean": "rimraf coverage dist sbin",
    "format": "prettier ./src --write",
    "prisma:enums": "tsx ./src/db/codes/generate.ts",
    "knex:local": "tsx ./node_modules/knex/bin/cli.js",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "migrate:down": "knex migrate:down",
    "migrate:latest": "knex migrate:latest",
    "migrate:list": "knex migrate:list",
    "migrate:rollback:all": "knex migrate:rollback --all",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:up": "knex migrate:up",
    "migrate": "knex migrate:latest --knexfile ./sbin/knexfile.js",
    "peach:sync": "node sbin/peachSync.js",
    "peach:sync:local": "tsx ./peachSync.ts",
    "postbuild:all": "npm run build",
    "postbuild": "tsx ./deploy-utils.ts docs",
    "postclean:all": "npm run clean",
    "postprisma:case": "npm run prisma:sync",
    "postprisma:migrate:rollback": "npm run prisma:sync",
    "postprisma:migrate:down": "npm run prisma:sync",
    "postprisma:migrate:up": "npm run prisma:sync",
    "postprisma:migrate:dev": "npm run seed:dev",
    "postprisma:migrate": "npm run prisma:case",
    "postprisma:sync": "npm run prisma:generate",
    "postrebuild": "npm run build",
    "postreinstall": "npm install",
    "postseed:dev": "npm run prisma:sync",
    "posttest": "tsx ./lcov-fix.ts",
    "prelint": "npm run typecheck",
    "prelint:fix": "npm run typecheck",
    "pretest": "npm run lint",
    "prisma:case": "prisma-case-format -f \"./src/db/prisma/schema.prisma\" --table-case=snake --field-case=camel --enum-case=snake",
    "prisma:generate": "prisma generate",
    "prisma:migrate:rollback": "npm run knex:local migrate:rollback",
    "prisma:migrate:down": "npm run knex:local migrate:down",
    "prisma:migrate:up": "npm run knex:local migrate:up",
    "prisma:migrate:dev": "npm run knex:local migrate:latest",
    "prisma:migrate": "npm run knex:local migrate:latest",
    "prisma:sync": "prisma db pull",
    "purge": "rimraf node_modules",
    "rebuild": "npm run clean",
    "reinstall": "npm run purge",
    "seed:make": "knex seed:make",
    "seed:dev": "tsx ./node_modules/knex/bin/cli.js seed:run --specific=dev_groups.ts",
    "seed:housing": "tsx ./node_modules/knex/bin/cli.js seed:run --specific=housing_projects.ts",
    "seed": "knex seed:run",
    "dev": "tsx watch --include \"./config/*\" --include \"./src/**/*\" ./server.ts --clear-screen=false",
    "start": "tsx ./server.ts",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "6.16.1",
    "@tsconfig/node24": "24.0.4",
    "@types/proj4": "2.19.0",
    "axios": "1.16.1",
    "compression": "1.8.1",
    "config": "4.4.1",
    "cors": "2.8.6",
    "date-fns": "4.4.0",
    "express": "5.2.1",
    "express-winston": "4.2.0",
    "helmet": "8.2.0",
    "joi": "18.2.1",
    "js-yaml": "4.2.0",
    "jsonwebtoken": "9.0.3",
    "jwks-rsa": "4.0.1",
    "knex": "3.2.10",
    "lru-cache": "11.5.1",
    "pg": "8.21.0",
    "proj4": "2.20.8",
    "tsx": "4.22.4",
    "uuid": "11.1.0",
    "winston-transport": "4.9.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/compression": "1.8.1",
    "@types/config": "4.4.0",
    "@types/cors": "2.8.19",
    "@types/express": "5.0.6",
    "@types/express-serve-static-core": "5.1.1",
    "@types/js-yaml": "4.0.9",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "25.9.1",
    "@types/pg": "8.20.0",
    "@types/qs": "6.15.1",
    "@types/supertest": "7.2.0",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.4.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.8.0",
    "eslint-plugin-prettier": "5.5.6",
    "prettier": "3.8.3",
    "prisma": "6.16.1",
    "prisma-case-format": "2.2.1",
    "rimraf": "6.1.3",
    "supertest": "7.1.4",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "typescript-eslint": "8.60.1",
    "vitest": "4.1.8",
    "vitest-mock-extended": "2.0.0"
  },
  "prisma": {
    "schema": "src/db/prisma/schema.prisma"
  }
}
